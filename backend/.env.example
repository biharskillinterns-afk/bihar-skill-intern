# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=bihar_skill_intern
DB_PORT=3306
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_very_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
ADMIN_REGISTRATION_KEY=change_this_for_new_admins_after_first_setup
ALLOW_DEMO_PAYMENTS=false

# Razorpay Configuration
# Put real values only in backend/.env or deployed environment variables.
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_live_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Frontend URL
FRONTEND_URL=http://localhost:3000
